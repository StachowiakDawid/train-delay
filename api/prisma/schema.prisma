generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["typedSql"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// model station {
//   id   Int    @id(map: "station_pk") @default(autoincrement())
//   name String @unique @db.VarChar
//   // stop stop[]
// }

model route {
  id         Int          @id(map: "route_pk") @default(autoincrement())
  route      String       @unique @db.VarChar
  connection connection[]
}

model time_offset {
  id          Int          @id(map: "time_offset_pk") @default(autoincrement())
  offsets     Int[]
  arrivals    connection[] @relation("arrivals_offsets")
  departments connection[] @relation("departments_offsets")
}

model connection {
  id                     Int         @id(map: "connection_pk") @default(autoincrement())
  department_date        DateTime    @db.Timestamp(0)
  // name            String   @db.VarChar
  operator               String      @db.VarChar
  // destination     String   @db.VarChar
  // connection_type String   @db.VarChar
  // description     String   @db.VarChar
  // stops                  stop[]
  // pkp_id          String   @db.VarChar
  route_id               Int
  route                  route       @relation(fields: [route_id], references: [id])
  arrivals_offsets_id    Int
  arrivals_offsets       time_offset @relation(fields: [arrivals_offsets_id], references: [id], name: "arrivals_offsets")
  departments_offsets_id Int
  departments_offsets    time_offset @relation(fields: [departments_offsets_id], references: [id], name: "departments_offsets")
  arrival_delays         Int[]
  department_delays      Int[]
  cancelled              Boolean[]
}

