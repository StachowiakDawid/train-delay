{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "train-delay": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1000kB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "externalDependencies": [
                "util"
              ]
            },
            "pglite": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1000kB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "externalDependencies": [
                "util"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment-pglite.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public"
                },
                {
                  "glob": "pglite.wasm",
                  "input": "node_modules/@electric-sql/pglite/dist",
                  "output": "/"
                },
                {
                  "glob": "pglite.data",
                  "input": "node_modules/@electric-sql/pglite/dist",
                  "output": "/"
                }
              ],
              "allowedCommonJsDependencies": [
                "@electric-sql/pglite"
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "externalDependencies": [
                "util"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "pglite-development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "externalDependencies": [
                "util"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment-pglite.development.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public"
                },
                {
                  "glob": "pglite.wasm",
                  "input": "node_modules/@electric-sql/pglite/dist",
                  "output": "/"
                },
                {
                  "glob": "pglite.data",
                  "input": "node_modules/@electric-sql/pglite/dist",
                  "output": "/"
                }
              ],
              "allowedCommonJsDependencies": [
                "@electric-sql/pglite"
              ]
            },
            "duckdb-development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "externalDependencies": [
                "util"
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public"
                },
                {
                  "glob": "duckdb-mvp.wasm",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-mvp.worker.js",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-mvp.worker.js.map",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-eh.wasm",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-eh.worker.js",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-eh.worker.js.map",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment-duckdb.development.ts"
                }
              ]
            },
            "duckdb": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1000kB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "externalDependencies": [
                "util"
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public"
                },
                {
                  "glob": "duckdb-mvp.wasm",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-mvp.worker.js",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-mvp.worker.js.map",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-eh.wasm",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-eh.worker.js",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                },
                {
                  "glob": "duckdb-browser-eh.worker.js.map",
                  "input": "node_modules/@duckdb/duckdb-wasm/dist",
                  "output": "/"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment-duckdb.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "train-delay:build:production"
            },
            "pglite": {
              "buildTarget": "train-delay:build:pglite"
            },
            "development": {
              "buildTarget": "train-delay:build:development"
            },
            "pglite-development": {
              "buildTarget": "train-delay:build:pglite-development"
            },
            "duckdb-development": {
              "buildTarget": "train-delay:build:duckdb-development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "src/proxy.conf.json",
            "prebundle": false
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ]
          }
        }
      }
    }
  }
}